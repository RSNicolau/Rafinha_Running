# Database (Supabase connection string)
# Use pgbouncer=true URL for the app (connection pooling via PgBouncer)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true
# Use direct URL for Prisma migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis (Railway Redis addon or Upstash)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
APP_URL=https://your-api.railway.app
MOBILE_DEEP_LINK=rrrafinha://

# Pagar.me
PAGARME_API_KEY=sk_live_xxxxx
PAGARME_WEBHOOK_SECRET=whsec_xxxxx

# Stripe (international)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxx

# Mercado Pago (Brazil)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxx
MERCADOPAGO_WEBHOOK_SECRET=xxxxx

# Strava OAuth
STRAVA_CLIENT_ID=xxxxx
STRAVA_CLIENT_SECRET=xxxxx
STRAVA_REDIRECT_URI=https://your-api.railway.app/auth/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=xxxxx

# Garmin
GARMIN_CLIENT_ID=xxxxx
GARMIN_CLIENT_SECRET=xxxxx
GARMIN_REDIRECT_URI=https://your-api.railway.app/auth/garmin/callback

# COROS Open API
COROS_CLIENT_ID=xxxxx
COROS_CLIENT_SECRET=xxxxx
COROS_REDIRECT_URI=https://your-api.railway.app/api/integrations/COROS/callback

# Polar AccessLink API
POLAR_CLIENT_ID=xxxxx
POLAR_CLIENT_SECRET=xxxxx
POLAR_REDIRECT_URI=https://your-api.railway.app/api/integrations/POLAR/callback
POLAR_WEBHOOK_SECRET=xxxxx   # Generated during setup-webhook, store here for validation

# Google Fit
GOOGLE_FIT_CLIENT_ID=xxxxx
GOOGLE_FIT_CLIENT_SECRET=xxxxx
GOOGLE_FIT_REDIRECT_URI=https://your-api.railway.app/api/integrations/GOOGLE_FIT/callback

# Sentry Error Tracking (get DSN at sentry.io — create a Node.js/NestJS project)
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# Expo Push Notifications
EXPO_ACCESS_TOKEN=xxxxx

# Supabase Storage (for logo/banner uploads)
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Transactional email (Resend — resend.com, free tier: 3k emails/month)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com
PLATFORM_NAME=Rafinha Running

# Anthropic AI (Claude) — get API key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
