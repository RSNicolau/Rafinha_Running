generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ATHLETE
  COACH
  ADMIN
  SUPER_ADMIN
}

enum AthleteLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum PlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  PAUSED
}

enum WorkoutType {
  EASY_RUN
  TEMPO
  INTERVAL
  LONG_RUN
  RECOVERY
  RACE
  CROSS_TRAINING
  REST
}

enum WorkoutStatus {
  SCHEDULED
  COMPLETED
  SKIPPED
  MISSED
}

enum WorkoutSource {
  MANUAL
  GARMIN
  STRAVA
  APPLE_HEALTH
  GOOGLE_FIT
  COROS
  POLAR
}

enum HeartRateZone {
  Z1_RECOVERY
  Z2_EASY
  Z3_AEROBIC
  Z4_THRESHOLD
  Z5_MAXIMUM
}

enum IntegrationProvider {
  GARMIN
  STRAVA
  APPLE_HEALTH
  GOOGLE_FIT
  COROS
  POLAR
}

enum SubscriptionPlanType {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  TRIAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum PaymentProvider {
  STRIPE
  MERCADO_PAGO
  PAGARME
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  PENDING
  REFUNDED
}

enum NotificationType {
  WORKOUT_REMINDER
  WORKOUT_COMPLETED
  NEW_MESSAGE
  PLAN_ASSIGNED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SUBSCRIPTION_EXPIRING
  COACH_FEEDBACK
  EVENT_REMINDER
  EVENT_REGISTRATION
  SYSTEM
}

enum EventStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  COMPLETED
  CANCELED
}

enum EventRegistrationStatus {
  PENDING
  CONFIRMED
  CANCELED
  WAITLIST
  CHECKED_IN
  ABSENT
}

enum KitType {
  COMPLETO
  PREMIUM
}

enum AIAssistantTone {
  FRIENDLY
  PROFESSIONAL
  MOTIVATIONAL
}

enum SportNiche {
  RUNNING
  CYCLING
  TRIATHLON
  SWIMMING
  CROSSFIT
  FITNESS
  GENERAL
}

// ============================================
// MODELS
// ============================================

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(ATHLETE)
  avatarUrl    String?   @map("avatar_url")
  phone        String?
  dateOfBirth  DateTime? @map("date_of_birth")
  isActive     Boolean   @default(true) @map("is_active")
  timezone     String    @default("America/Sao_Paulo") @map("timezone")
  appleId      String?   @unique @map("apple_id")
  deletedAt    DateTime? @map("deleted_at")

  // AI provider settings (coach only)
  aiProvider   String    @default("anthropic") @map("ai_provider") // anthropic | openai | gemini | grok
  aiModel      String?   @map("ai_model")      // override default model per provider
  aiByok       Boolean   @default(false) @map("ai_byok") // true = coach uses own API key
  aiApiKey     String?   @map("ai_api_key")    // encrypted, only used when aiByok=true

  // 2FA TOTP (coaches)
  totpSecret   String?   @map("totp_secret")   // encrypted base32 secret
  totpEnabled  Boolean   @default(false) @map("totp_enabled")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([role])
  @@index([isActive])

  coachProfile   CoachProfile?
  athleteProfile AthleteProfile?
  coachAthletes  AthleteProfile[] @relation("CoachAthletes")
  integrations   FitnessIntegration[]
  subscriptions  Subscription[]
  payments       Payment[]
  notifications  Notification[]
  sentMessages   Message[]             @relation("MessageSender")

  // Coach relations
  coachPlans     TrainingPlan[]        @relation("CoachPlans")
  coachConvos    Conversation[]        @relation("CoachConversations")

  // Athlete relations
  athletePlans   TrainingPlan[]        @relation("AthletePlans")
  athleteWorkouts Workout[]
  athleteConvos  Conversation[]        @relation("AthleteConversations")

  // Event relations
  createdEvents      Event[]              @relation("EventCreator")
  eventRegistrations EventRegistration[]  @relation("EventRegistrations")

  tenantBranding TenantBranding?

  sentInvites     CoachInvite[] @relation("CoachInvites")
  receivedInvites CoachInvite[] @relation("AthleteInvites")

  nutritionLogs NutritionLog[]
  waterLogs     WaterLog[]
  aiAssistantConfig AIAssistantConfig?

  garminHealthSnapshots GarminHealthSnapshot[] @relation("AthleteGarminSnapshots")
  onboardingForm        OnboardingForm?        @relation("CoachOnboardingForm")
  onboardingProfile     OnboardingProfile?     @relation("AthleteOnboarding")
  coachOnboardings      OnboardingProfile[]    @relation("CoachOnboardings")
  athleteAssessments    PhysicalAssessment[]   @relation("AthleteAssessments")
  coachAssessments      PhysicalAssessment[]   @relation("CoachAssessments")
  coachBrainSessions    CoachBrainSession[]    @relation("CoachBrainSessions")

  // Platform billing
  coachSubscription     CoachSubscription?     @relation("CoachSubscription")
  whiteLabelAccount     WhiteLabelAccount?     @relation("WhiteLabelOwner")

  // Badges
  athleteBadges         AthleteBadge[]         @relation("AthleteBadges")

  @@map("users")
}

model CoachProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  slug            String?  @unique
  bio             String?
  specializations String[] @default([])
  certifications  String[] @default([])
  maxAthletes     Int      @default(30) @map("max_athletes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Payment gateway — Modelo 2 (each coach uses own account)
  paymentProvider      String?  @default("pagarme") @map("payment_provider") // pagarme | stripe
  pagarmeApiKey        String?  @map("pagarme_api_key")          // encrypted AES-256
  pagarmeWebhookSecret String?  @map("pagarme_webhook_secret")   // encrypted AES-256
  stripeSecretKey      String?  @map("stripe_secret_key")        // encrypted AES-256
  stripeWebhookSecret  String?  @map("stripe_webhook_secret")    // encrypted AES-256
  paymentEnabled       Boolean  @default(false) @map("payment_enabled")
  niche                SportNiche @default(RUNNING) @map("niche")
  nicheConfig          Json?      @map("niche_config") // custom branding/pricing overrides
  appointmentUrl       String?    @map("appointment_url")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coach_profiles")
}

model AthleteProfile {
  id           String       @id @default(uuid())
  userId       String       @unique @map("user_id")
  coachId      String?      @map("coach_id")
  weight       Float?
  height       Float?
  vo2max       Float?
  restingHR    Int?         @map("resting_hr")
  maxHR        Int?         @map("max_hr")
  weeklyGoalKm Float?      @map("weekly_goal_km")
  level        AthleteLevel @default(BEGINNER)
  niche        SportNiche   @default(RUNNING) @map("niche")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  coach User? @relation("CoachAthletes", fields: [coachId], references: [id])

  @@index([coachId])
  @@map("athlete_profiles")
}

model TrainingPlan {
  id              String     @id @default(uuid())
  coachId         String     @map("coach_id")
  athleteId       String     @map("athlete_id")
  name            String
  description     String?
  startDate       DateTime   @map("start_date")
  endDate         DateTime   @map("end_date")
  status          PlanStatus @default(DRAFT)
  weeklyFrequency Int        @default(3) @map("weekly_frequency")
  deletedAt       DateTime?  @map("deleted_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  coach    User      @relation("CoachPlans", fields: [coachId], references: [id])
  athlete  User      @relation("AthletePlans", fields: [athleteId], references: [id])
  workouts Workout[]

  @@index([athleteId, status])
  @@index([coachId])
  @@index([status])
  @@map("training_plans")
}

model Workout {
  id                    String        @id @default(uuid())
  planId                String        @map("plan_id")
  athleteId             String        @map("athlete_id")
  scheduledDate         DateTime      @map("scheduled_date")
  type                  WorkoutType
  title                 String
  description           String?
  targetDistanceMeters  Int?          @map("target_distance_meters")
  targetDurationSeconds Int?          @map("target_duration_seconds")
  targetPace            String?       @map("target_pace")
  heartRateZone         HeartRateZone? @map("heart_rate_zone")
  status                WorkoutStatus @default(SCHEDULED)
  completedAt           DateTime?     @map("completed_at")
  coachNotes            String?       @map("coach_notes")
  garminWorkoutId       String?       @map("garmin_workout_id")
  garminScheduleId      String?       @map("garmin_schedule_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  plan    TrainingPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  athlete User           @relation(fields: [athleteId], references: [id])
  result  WorkoutResult?

  @@index([athleteId, scheduledDate])
  @@index([athleteId, status])
  @@index([planId])
  @@index([type])
  @@index([completedAt])
  @@map("workouts")
}

model WorkoutResult {
  id             String        @id @default(uuid())
  workoutId      String        @unique @map("workout_id")
  source         WorkoutSource @default(MANUAL)
  externalId     String?       @map("external_id")
  distanceMeters Int           @map("distance_meters")
  durationSeconds Int          @map("duration_seconds")
  avgPace        String?       @map("avg_pace")
  avgHeartRate   Int?          @map("avg_heart_rate")
  maxHeartRate   Int?          @map("max_heart_rate")
  calories       Int?
  elevationGain  Float?        @map("elevation_gain")
  splits           Json?
  gpsRoute         Json?         @map("gps_route")
  rpe              Int?
  sensationScore   Int?          @map("sensation_score")
  athleteFeedback  String?       @map("athlete_feedback")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([createdAt])
  @@map("workout_results")
}

model FitnessIntegration {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  provider        IntegrationProvider
  accessToken     String              @map("access_token")
  refreshToken    String?             @map("refresh_token")
  expiresAt       DateTime?           @map("expires_at")
  externalUserId  String?             @map("external_user_id")
  isActive        Boolean             @default(true) @map("is_active")
  lastSyncAt      DateTime?           @map("last_sync_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([isActive])
  @@index([provider])
  @@index([expiresAt])
  @@map("fitness_integrations")
}

model Subscription {
  id                     String               @id @default(uuid())
  userId                 String               @map("user_id")
  planType               SubscriptionPlanType  @map("plan_type")
  status                 SubscriptionStatus    @default(INCOMPLETE)
  provider               PaymentProvider
  externalSubscriptionId String?               @unique @map("external_subscription_id")
  currentPeriodStart     DateTime              @map("current_period_start")
  currentPeriodEnd       DateTime              @map("current_period_end")
  cancelAtPeriodEnd      Boolean               @default(false) @map("cancel_at_period_end")
  trialEnd               DateTime?             @map("trial_end")
  gracePeriodEnd         DateTime?             @map("grace_period_end")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@index([userId, status])
  @@index([externalSubscriptionId])
  @@index([provider])
  @@map("subscriptions")
}

model Payment {
  id                String          @id @default(uuid())
  subscriptionId    String?         @map("subscription_id")
  userId            String          @map("user_id")
  amount            Int
  currency          String          @default("BRL")
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider
  externalPaymentId String?         @unique @map("external_payment_id")
  paidAt            DateTime?       @map("paid_at")
  // Pagar.me v5 specific fields
  pixQrCode         String?         @map("pix_qr_code")
  pixQrCodeUrl      String?         @map("pix_qr_code_url")
  pixExpiresAt      DateTime?       @map("pix_expires_at")
  planId            String?         @map("plan_id")
  deletedAt         DateTime?       @map("deleted_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([subscriptionId])
  @@index([paidAt])
  @@map("payments")
}

model Conversation {
  id            String    @id @default(uuid())
  athleteId     String    @map("athlete_id")
  coachId       String    @map("coach_id")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  athlete  User      @relation("AthleteConversations", fields: [athleteId], references: [id])
  coach    User      @relation("CoachConversations", fields: [coachId], references: [id])
  messages Message[]

  @@unique([athleteId, coachId])
  @@index([athleteId])
  @@index([coachId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type])
  @@map("notifications")
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_configs")
}

// ============================================
// EVENTS
// ============================================

model Event {
  id             String      @id @default(uuid())
  createdById    String      @map("created_by_id")
  title          String
  description    String?
  coverImageUrl  String?     @map("cover_image_url")
  eventDate      DateTime    @map("event_date")
  eventEndDate   DateTime?   @map("event_end_date")
  location       String?
  city           String?
  state          String?
  modality       String?     // 5K, 10K, 21K, 42K, Trail, Ultra
  maxParticipants Int?       @map("max_participants")
  price          Int         @default(0)  // cents BRL (0 = free)
  currency       String      @default("BRL")
  status         EventStatus @default(DRAFT)
  tags           String[]    @default([])
  rules          String?
  kitDescription     String?   @map("kit_description")
  kitCompletePrice   Int?      @map("kit_complete_price")   // cents — Kit Completo
  kitPremiumPrice    Int?      @map("kit_premium_price")    // cents — Kit Premium
  kitPickupLocation  String?   @map("kit_pickup_location")  // endereço de retirada
  kitPickupDate      DateTime? @map("kit_pickup_date")      // data/hora de retirada
  routeMapUrl        String?   @map("route_map_url")
  latitude           Float?    @map("latitude")
  longitude          Float?    @map("longitude")
  meetingPoint       String?   @map("meeting_point")
  meetingPointLat    Float?    @map("meeting_point_lat")
  meetingPointLng    Float?    @map("meeting_point_lng")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  createdBy     User                @relation("EventCreator", fields: [createdById], references: [id])
  registrations EventRegistration[]

  @@index([eventDate])
  @@index([status])
  @@index([createdById])
  @@index([modality])
  @@map("events")
}

model EventRegistration {
  id               String                  @id @default(uuid())
  eventId          String                  @map("event_id")
  userId           String                  @map("user_id")
  status           EventRegistrationStatus @default(PENDING)
  paymentStatus    PaymentStatus           @default(PENDING)
  externalPaymentId String?                @map("external_payment_id")
  bibNumber              String?   @map("bib_number")
  shirtSize              String?   @map("shirt_size")
  kitType                KitType?  @map("kit_type")                          // COMPLETO | PREMIUM
  kitPickupScheduledAt   DateTime? @map("kit_pickup_scheduled_at")           // agendamento retirada
  kitPickupConfirmed     Boolean   @default(false) @map("kit_pickup_confirmed")
  emergencyContact       String?   @map("emergency_contact")
  medicalInfo            String?   @map("medical_info")
  registeredAt           DateTime  @default(now()) @map("registered_at")
  confirmedAt            DateTime? @map("confirmed_at")
  checkinAt              DateTime? @map("checkin_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation("EventRegistrations", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@map("event_registrations")
}

// ============================================
// INVITES
// ============================================

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model CoachInvite {
  id        String       @id @default(uuid())
  coachId   String       @map("coach_id")
  email     String
  token     String       @unique @default(uuid())
  status    InviteStatus @default(PENDING)
  expiresAt DateTime     @map("expires_at")
  acceptedAt DateTime?   @map("accepted_at")
  athleteId  String?     @map("athlete_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  coach   User  @relation("CoachInvites", fields: [coachId], references: [id], onDelete: Cascade)
  athlete User? @relation("AthleteInvites", fields: [athleteId], references: [id])

  @@index([coachId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("coach_invites")
}

model NutritionLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @map("date") @db.Date
  mealName  String   @map("meal_name")
  mealTime  String?  @map("meal_time")
  calories  Int      @default(0)
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  items     String[] @default([])
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@map("nutrition_logs")
}

model WaterLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @map("date") @db.Date
  amount    Int      // ml
  goal      Int      @default(3000) // ml
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("water_logs")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_id")   // user who performed the action
  action     String                      // DELETE_USER, CANCEL_SUBSCRIPTION, etc.
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TenantBranding {
  id           String   @id @default(uuid())
  coachId      String   @unique @map("coach_id")
  tenantName   String   @map("tenant_name")
  primaryColor String   @default("#DC2626") @map("primary_color")
  logoUrl        String?  @map("logo_url")
  bannerUrl      String?  @map("banner_url")
  domain         String?  @unique
  welcomeMsg     String?  @map("welcome_msg")
  secondaryColor String?  @default("#1F2937") @map("secondary_color")
  niche          String?  @default("running") @map("niche")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@map("tenant_brandings")
}

model AIAssistantConfig {
  id            String          @id @default(uuid())
  coachId       String          @unique @map("coach_id")
  assistantName String          @default("Rafinha") @map("assistant_name")
  tone          AIAssistantTone @default(FRIENDLY)
  personaPrompt String?         @map("persona_prompt")
  voiceEnabled  Boolean         @default(false) @map("voice_enabled")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  coach         User            @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@map("ai_assistant_configs")
}

// ============================================
// GARMIN HEALTH SNAPSHOTS
// ============================================

model GarminHealthSnapshot {
  id             String   @id @default(uuid())
  athleteId      String   @map("athlete_id")
  date           DateTime @map("date") @db.Date
  sleepScore     Int?     @map("sleep_score")
  sleepHours     Float?   @map("sleep_hours")
  hrv            Int?
  stressScore    Int?     @map("stress_score")
  restingHR      Int?     @map("resting_hr")
  steps          Int?
  spo2           Float?
  caloriesActive Int?     @map("calories_active")
  createdAt      DateTime @default(now()) @map("created_at")

  athlete User @relation("AthleteGarminSnapshots", fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, date])
  @@index([athleteId])
  @@map("garmin_health_snapshots")
}

// ============================================
// ONBOARDING
// ============================================

enum QuestionType {
  TEXT
  TEXTAREA
  SELECT
  MULTISELECT
  NUMBER
  TIME
  DATE
  SCALE
  BOOLEAN
}

enum OnboardingStatus {
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  PLAN_GENERATED
}

model OnboardingForm {
  id          String               @id @default(uuid())
  coachId     String               @unique @map("coach_id")
  title       String               @default("Questionário de Anamnese")
  description String?
  isActive    Boolean              @default(true) @map("is_active")
  niche       SportNiche           @default(RUNNING) @map("niche")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  coach     User                 @relation("CoachOnboardingForm", fields: [coachId], references: [id], onDelete: Cascade)
  questions OnboardingQuestion[]

  @@map("onboarding_forms")
}

model OnboardingQuestion {
  id          String       @id @default(uuid())
  formId      String       @map("form_id")
  order       Int
  question    String
  type        QuestionType
  options     Json?
  required    Boolean      @default(true)
  placeholder String?
  aiHint      String?      @map("ai_hint")
  isActive    Boolean      @default(true) @map("is_active")

  form OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
  @@map("onboarding_questions")
}

model OnboardingProfile {
  id            String           @id @default(uuid())
  athleteId     String           @unique @map("athlete_id")
  coachId       String           @map("coach_id")
  answers       Json
  parsedProfile Json?            @map("parsed_profile")
  aiSummary     String?          @map("ai_summary")
  status        OnboardingStatus @default(PENDING_REVIEW)
  completedAt   DateTime?        @map("completed_at")
  reviewedAt    DateTime?        @map("reviewed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  athlete User @relation("AthleteOnboarding", fields: [athleteId], references: [id], onDelete: Cascade)
  coach   User @relation("CoachOnboardings", fields: [coachId], references: [id])

  @@index([coachId, status])
  @@map("onboarding_profiles")
}

// ============================================
// PHYSICAL ASSESSMENTS
// ============================================

model PhysicalAssessment {
  id             String   @id @default(uuid())
  athleteId      String   @map("athlete_id")
  coachId        String   @map("coach_id")
  assessedAt     DateTime @map("assessed_at")

  weightKg       Float?   @map("weight_kg")
  heightCm       Float?   @map("height_cm")
  bmi            Float?
  bodyFatPct     Float?   @map("body_fat_pct")
  muscleMassPct  Float?   @map("muscle_mass_pct")

  restingHR      Int?     @map("resting_hr")
  maxHR          Int?     @map("max_hr")
  vo2max         Float?

  best5kTime     Int?     @map("best_5k_time")
  best10kTime    Int?     @map("best_10k_time")
  vdot           Float?

  flexScore      Int?     @map("flex_score")
  strengthScore  Int?     @map("strength_score")

  hrZones        Json?    @map("hr_zones")
  paceZones      Json?    @map("pace_zones")

  aiAnalysis     String?  @map("ai_analysis")
  coachNotes     String?  @map("coach_notes")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  athlete User @relation("AthleteAssessments", fields: [athleteId], references: [id], onDelete: Cascade)
  coach   User @relation("CoachAssessments", fields: [coachId], references: [id])

  @@index([athleteId, assessedAt])
  @@map("physical_assessments")
}

// ============================================
// COACH BRAIN — AI SESSIONS & JOBS
// ============================================

model CoachBrainSession {
  id        String   @id @default(uuid())
  coachId   String   @map("coach_id")
  title     String?
  messages  Json     @default("[]")
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  coach User @relation("CoachBrainSessions", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@map("coach_brain_sessions")
}

// ============================================
// LOJA VIRTUAL
// ============================================

enum ProductCategory {
  CAMISA
  VISEIRA
  BONE
  CASACO
  CORTA_VENTO
  MEIA
  CALCA
  SHORTS
  ACESSORIO
  OUTRO
}

enum StoreOrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Product {
  id            String          @id @default(uuid())
  coachId       String          @map("coach_id")
  name          String
  description   String?
  category      ProductCategory @default(OUTRO)
  priceInCents  Int             @default(0) @map("price_in_cents")
  images        String[]        @default([])
  sizes         String[]        @default([])
  colors        String[]        @default([])
  totalStock    Int             @default(0) @map("total_stock")
  reserved      Int             @default(0)
  active        Boolean         @default(true)
  featured      Boolean         @default(false)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  orders StoreOrder[]

  @@index([coachId, active])
  @@index([category])
  @@map("products")
}

model StoreOrder {
  id              String           @id @default(uuid())
  productId       String           @map("product_id")
  athleteId       String?          @map("athlete_id")
  customerName    String           @map("customer_name")
  customerEmail   String           @map("customer_email")
  customerPhone   String?          @map("customer_phone")
  size            String?
  color           String?
  quantity        Int              @default(1)
  totalInCents    Int              @map("total_in_cents")
  status          StoreOrderStatus @default(PENDING_PAYMENT)
  paymentId       String?          @map("payment_id")
  paymentUrl      String?          @map("payment_url")
  shippingAddress String?          @map("shipping_address")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([status])
  @@index([customerEmail])
  @@map("store_orders")
}

// ============================================
// AGENDAMENTOS 1:1
// ============================================

enum AppointmentType {
  ONLINE_CONSULT
  PRESENTIAL_TRAINING
  ASSESSMENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id              String            @id @default(uuid())
  coachId         String            @map("coach_id")
  athleteId       String?           @map("athlete_id")
  customerName    String            @map("customer_name")
  customerEmail   String            @map("customer_email")
  customerPhone   String?           @map("customer_phone")
  type            AppointmentType   @default(ONLINE_CONSULT)
  status          AppointmentStatus @default(PENDING)
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @default(60) @map("duration_minutes")
  priceInCents    Int               @default(30000) @map("price_in_cents")
  calendlyEventId String?           @map("calendly_event_id")
  calendlyUri     String?           @map("calendly_uri")
  notes           String?
  cancelledAt     DateTime?         @map("cancelled_at")
  cancelReason    String?           @map("cancel_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([coachId, scheduledAt])
  @@index([status])
  @@map("appointments")
}

// ============================================
// WHATSAPP AI
// ============================================

enum WhatsappMsgType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
  DOCUMENT
  STICKER
}

enum WhatsappMsgRole {
  USER
  ASSISTANT
}

model WhatsappConversation {
  id        String   @id @default(uuid())
  coachId   String   @map("coach_id")
  phone     String
  name      String?
  isActive  Boolean  @default(true) @map("is_active")
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages WhatsappMessage[]

  @@unique([coachId, phone])
  @@index([coachId])
  @@map("whatsapp_conversations")
}

model WhatsappMessage {
  id             String          @id @default(uuid())
  conversationId String          @map("conversation_id")
  role           WhatsappMsgRole
  type           WhatsappMsgType @default(TEXT)
  content        String?
  mediaUrl       String?         @map("media_url")
  externalId     String?         @map("external_id")
  processed      Boolean         @default(false)
  createdAt      DateTime        @default(now()) @map("created_at")

  conversation WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("whatsapp_messages")
}

model AIJob {
  id         String    @id @default(uuid())
  type       String
  status     String    @default("PENDING")
  retries    Int       @default(0)
  maxRetries Int       @default(3) @map("max_retries")
  payload    Json
  result     Json?
  error      String?
  coachId    String?   @map("coach_id")
  athleteId  String?   @map("athlete_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([status, retries])
  @@index([coachId])
  @@map("ai_jobs")
}

// ============================================
// PLATFORM PLANS & WHITE-LABEL (3-tier SaaS)
// ============================================

enum PlatformPlanType {
  STARTER     // R$197/mês — até 30 atletas
  PRO         // R$397/mês — até 100 atletas
  SCALE       // R$697/mês — até 300 atletas
  ELITE       // R$997/mês — ilimitado
  WHITE_LABEL // R$1.497/mês — ilimitado + pode criar coaches
}

enum CoachSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum WhiteLabelStatus {
  ACTIVE
  SUSPENDED
  CANCELED
}

model PlatformPlan {
  id            String          @id @default(uuid())
  type          PlatformPlanType @unique
  name          String
  description   String?
  priceInCents  Int             @map("price_in_cents")
  maxAthletes   Int?            @map("max_athletes")   // null = unlimited
  maxCoaches    Int?            @map("max_coaches")    // only for WHITE_LABEL
  features      Json            @default("[]")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  subscriptions CoachSubscription[]

  @@map("platform_plans")
}

model CoachSubscription {
  id                  String                  @id @default(uuid())
  coachId             String                  @unique @map("coach_id")
  planId              String                  @map("plan_id")
  status              CoachSubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?               @map("trial_ends_at")
  currentPeriodStart  DateTime                @default(now()) @map("current_period_start")
  currentPeriodEnd    DateTime                @map("current_period_end")
  externalId          String?                 @map("external_id")   // MercadoPago subscription ID
  whiteLabelId        String?                 @map("white_label_id") // if managed by a WL account
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  coach       User              @relation("CoachSubscription", fields: [coachId], references: [id], onDelete: Cascade)
  plan        PlatformPlan      @relation(fields: [planId], references: [id])
  whiteLabel  WhiteLabelAccount? @relation(fields: [whiteLabelId], references: [id])

  @@index([status])
  @@index([whiteLabelId])
  @@map("coach_subscriptions")
}

model WhiteLabelAccount {
  id             String           @id @default(uuid())
  ownerId        String           @unique @map("owner_id")
  brandName      String           @map("brand_name")
  customDomain   String?          @unique @map("custom_domain")
  logoUrl        String?          @map("logo_url")
  primaryColor   String?          @map("primary_color")
  maxCoaches     Int              @default(5) @map("max_coaches")
  status         WhiteLabelStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  owner          User              @relation("WhiteLabelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  coaches        CoachSubscription[]

  @@map("white_label_accounts")
}

// ============================================
// BADGES & ACHIEVEMENTS
// ============================================

model Badge {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String
  icon        String
  category    String   @default("performance") // performance | consistency | milestone
  createdAt   DateTime @default(now()) @map("created_at")

  athleteBadges AthleteBadge[]

  @@map("badges")
}

model AthleteBadge {
  id        String   @id @default(uuid())
  athleteId String   @map("athlete_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")
  metadata  Json?

  athlete User  @relation("AthleteBadges", fields: [athleteId], references: [id], onDelete: Cascade)
  badge   Badge @relation(fields: [badgeId], references: [id])

  @@unique([athleteId, badgeId])
  @@index([athleteId])
  @@map("athlete_badges")
}
