{
  "expo": {
    "name": "RR - Rafinha Running",
    "slug": "rr-rafinha-running",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rrrafinha",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#DE3B2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rafinharunning.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DE3B2E"
      },
      "package": "com.rafinharunning.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "react-native-health",
        {
          "isClinicalHealthRecordsEnabled": false,
          "isBackgroundDeliveryEnabled": true,
          "NSHealthShareUsageDescription": "O app precisa acessar seus dados de corrida (distância, frequência cardíaca, pace) para sincronizar automaticamente com seu treinador.",
          "NSHealthUpdateUsageDescription": "O app pode salvar seus treinos no Apple Health para manter um histórico unificado de atividades."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "./plugins/withRNHealthSwiftFix"
    ],
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "34d8880d-2a9c-4163-9a04-07305e629b0e"
      }
    },
    "owner": "rafinharunning"
  }
}
