# Backend API URL (used in Next.js rewrites — server-side only)
# Local dev: leave empty (defaults to http://localhost:3000)
# Staging: set to your Railway URL
API_URL=https://your-api.railway.app

# Sentry Error Tracking (get DSN at sentry.io — create a Next.js project)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_AUTH_TOKEN=sntrys_xxxx   # Required for source map uploads (Settings > Auth Tokens)

# Mapbox token for Live Tracking map (public key from mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoixxxxxx

# Pagar.me public encryption key (client-side card tokenization)
NEXT_PUBLIC_PAGARME_EK=ek_live_xxxxx
